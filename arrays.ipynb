   ],
   "source": [
    "#Reverse an array\n",
    "arr=[1,2,3,4,5,6]\n",
    "i=0\n",
    "j=len(arr)-1\n",
    "while i<=j:\n",
    "    arr[i],arr[j]=arr[j],arr[i]\n",
    "    i+=1\n",
    "    j-=1\n",
    "print(arr)"
   ]
  }
