   "source": [
    "#sum of array\n",
    "arr=[1,2,3,4,5]\n",
    "sum=0\n",
    "for i in range(len(arr)):\n",
    "    sum+=arr[i]\n",
    "print(\"Sum of the elements of the array :\",sum)"
   ]
  },
